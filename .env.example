# WQ Brain认证
WQ_USERNAME=your_username
WQ_PASSWORD=your_password

# LLM配置
LLM_PROVIDER=kimi
LLM_MODEL=
LLM_MAX_TOKENS=32768

# Kimi (火山引擎)
KIMI_API_KEY=your_volcengine_api_key
KIMI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions
KIMI_MODEL=kimi-k2.6

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_MODEL=deepseek-chat

# 回测参数
WQ_REGION=USA
WQ_UNIVERSE=TOP3000
WQ_DELAY=1
WQ_NEUTRALIZATION=INDUSTRY
WQ_TRUNCATION=0.08
WQ_PASTEURIZATION=ON
WQ_MAX_CONCURRENT=5

# 评估阈值
MIN_FITNESS=0.5
MIN_SHARPE=1.0
MAX_TURNOVER=0.7
MIN_RETURNS=0.05

# 数据库
DB_PATH=./wq_agent.db

# Quant Wiki
WIKI_DIR=./wiki
WIKI_RETRIEVE_TOP_K=5
WIKI_GREP_WEIGHT=7
WIKI_VECTOR_WEIGHT=3
WIKI_AUTO_RECORD=true
WIKI_SUMMARY_CHARS=200

# Embedding（向量通道；设为 none 关闭）
EMBEDDING_PROVIDER=none
EMBEDDING_MODEL=doubao-embedding-text-240715
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings
EMBEDDING_DIM=2048
