# WQ Brain认证
WQ_USERNAME=your_username
WQ_PASSWORD=your_password

# LLM配置
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.4
LLM_WIRE_API=auto
LLM_REASONING_EFFORT=
LLM_STORE=false
LLM_ALLOW_INSECURE_HTTP=false
LLM_CHAT_TOKEN_PARAM=max_tokens
LLM_CHAT_REASONING_EFFORT=false
LLM_MAX_TOKENS=32768
# 主生成采样温度；调高增大多样性、减少重复（refine 另用 0.55）
LLM_GEN_TEMPERATURE=0.5
ANTHROPIC_VERSION=2023-06-01

# openai_compatible covers OpenAI, DeepSeek, Kimi-compatible endpoints,
# OpenRouter, LiteLLM, and local proxies. For local no-auth servers,
# leave LLM_API_KEY empty and use localhost/127.0.0.1.
# For Anthropic Messages API:
# LLM_PROVIDER=anthropic
# LLM_BASE_URL=https://api.anthropic.com
# LLM_API_KEY=your_anthropic_key
# LLM_MODEL=claude-3-5-sonnet-latest

# Legacy provider aliases are still accepted for existing .env files.
# OPENAI_API_KEY=your_openai_or_proxy_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-5.4
# KIMI_API_KEY=your_volcengine_api_key
# KIMI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3/chat/completions
# KIMI_MODEL=kimi-k2.6
# DEEPSEEK_API_KEY=your_deepseek_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
# DEEPSEEK_MODEL=deepseek-chat

# 回测参数
WQ_REGION=USA
WQ_UNIVERSE=TOP3000
WQ_DELAY=1
WQ_NEUTRALIZATION=INDUSTRY
WQ_TRUNCATION=0.08
WQ_PASTEURIZATION=ON
WQ_MAX_CONCURRENT=5

# 评估阈值（默认与 WQ Brain 官方提交检查对齐）
# 评估器会优先用 WQ 返回的 checks 列表，这里只在 checks 缺失时 fallback
MIN_FITNESS=1.0
MIN_SHARPE=1.25
MIN_SUB_UNIVERSE_SHARPE=0.67
MIN_TURNOVER=0.01
MAX_TURNOVER=0.70
MIN_RETURNS=0.05

# 生成去重：同骨架历史最佳 fitness 始终 < 该值的结构，从新一批生成里排除（0 关闭）
DEDUP_FITNESS_FLOOR=0.3

# 数据库
DB_PATH=./wq_agent.db

# Quant Wiki
WIKI_DIR=./wiki
WIKI_RETRIEVE_TOP_K=5
WIKI_GREP_WEIGHT=7
WIKI_VECTOR_WEIGHT=3
WIKI_AUTO_RECORD=true
# 自动沉淀的真实 alpha/lesson 默认写入私有目录；该目录已 gitignore，适合开源仓
WIKI_AUTO_RECORD_DIR=./private_wiki
WIKI_SUMMARY_CHARS=200

# Embedding（向量通道；none 关闭 / local 本地 / volcengine / zhipu）
EMBEDDING_PROVIDER=local
# --- local (推荐): pip install fastembed，首次运行下载模型 ~95MB ---
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 想多语言更强用 BAAI/bge-m3 (~2GB, 1024 dim)；纯英文用 BAAI/bge-small-en-v1.5
EMBEDDING_DIM=0   # 0 = 自动检测
# --- 远程 API（仅 EMBEDDING_PROVIDER=volcengine/zhipu 时用）---
EMBEDDING_MODEL=doubao-embedding-text-240715
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings
